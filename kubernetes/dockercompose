version: '3.7'

services:
    nfs-server:
        image: itsthenetwork/nfs-server-alpine:latest
        container_name: nfs-server
        priviledged: true
        environment:
            SHARED_DIRECTOR: /exports
        volumes:
            - ./data/exports:rw
        ports:
            - '2049:2049'
        restart: unless-stopped